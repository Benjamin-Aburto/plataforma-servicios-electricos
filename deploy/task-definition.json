{
  "family": "contact-service-task",
  "networkMode": "awsvpc",
  "executionRoleArn": "arn:aws:iam::169917473443:role/LabRole",
  "containerDefinitions": [
    {
      "name": "contact-service",
      "image": "169917473443.dkr.ecr.us-east-1.amazonaws.com/contact-service:latest",
      "portMappings": [
        { "containerPort": 4000, "hostPort": 4000, "protocol": "tcp" }
      ],
      "essential": true
    }
  ],
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512"
}