# ============================================================
# Copia este archivo como ".env" y cambia los valores.
# NUNCA subas el archivo ".env" real a git.
# ============================================================

# --- MySQL (servicio: db) ---
MYSQL_ROOT_PASSWORD=cambia_esta_password_root
MYSQL_DATABASE=electric_services_db
MYSQL_USER=electric_app
MYSQL_PASSWORD=cambia_esta_password_app
MYSQL_PORT=3306

# --- General ---
NODE_ENV=production
CORS_ORIGIN=http://localhost:8080

# --- contact-service ---
CONTACT_SERVICE_PORT=4000

# --- portfolio-service ---
PORTFOLIO_SERVICE_PORT=4001

# --- notification-service ---
NOTIFICATION_SERVICE_PORT=4002

# --- frontend ---
FRONTEND_PORT=8080
# URLs públicas desde las que el NAVEGADOR del usuario llama a cada API
# (distinto de las URLs internas que usan los contenedores entre sí,
# como http://contact-service:4000, que solo existen dentro de la red Docker).
CONTACT_API_URL=http://localhost:4000/api
PORTFOLIO_API_URL=http://localhost:4001/api
